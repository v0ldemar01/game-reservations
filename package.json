{
  "name": "game-reservations",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:shared": "pnpm --filter @game-reservations/shared build",
    "build": "pnpm build:shared && pnpm --filter './apps/**' build",
    "dev:backend": "pnpm --filter @game-reservations/backend start:dev",
    "dev:frontend": "pnpm --filter @game-reservations/frontend dev",
    "test": "pnpm --filter './apps/**' test",
    "lint": "concurrently \"pnpm:lint:*\"",
    "lint:editor": "editorconfig-checker",
    "lint:files": "ls-lint",
    "lint:types": "pnpm -r --workspace-concurrency=1 run lint:types",
    "lint:js": "pnpm -r --workspace-concurrency=1 run lint:js",
    "lint:format": "npx prettier \"**/*.{js,ts,tsx,json,md}\" --check",
    "format": "npx prettier \"**/*.{js,ts,tsx,json,md}\" --write"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ls-lint/ls-lint": "2.3.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "concurrently": "9.2.1",
    "editorconfig-checker": "6.1.1",
    "eslint": "9.39.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-require-explicit-generics": "1.0.0",
    "eslint-plugin-sonarjs": "4.0.1",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lint-staged": "16.3.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}

# Backend environment variables
# Copy this file to apps/backend/.env and fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_reservations

# HTTP port the NestJS server listens on (default: 3000)
PORT=3000

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:5173

# JWT signing secret — MUST be at least 32 characters, keep it secret
JWT_SECRET=replace-with-a-long-random-string-of-at-least-32-chars

# Token expiry (default: 7d — accepts ms/zeit/vercel format: 60s, 15m, 7d, 1y)
JWT_EXPIRES_IN=7d

# Frontend build-time environment variables
# Copy these into apps/frontend/.env (Vite reads them at build time).

# Full URL to the GraphQL endpoint
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# Base URL of the REST API (used for CSV/ICS export downloads)
VITE_API_URL=http://localhost:3000
